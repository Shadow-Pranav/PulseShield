# Express Server Port
PORT=5000

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change_me_in_production

# Flask ML Engine URL
FLASK_API_URL=http://127.0.0.1:5001/predict

# MySQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=fraud_detection

# Flask Debug Mode
FLASK_DEBUG=false

# Node Environment
NODE_ENV=development
